{
  "name": "qa-automation-lab-api-pagamentos",
  "version": "1.0.0",
  "description": "Projeto de portfólio de automação de testes para uma API simulada de pagamentos.",
  "private": true,
  "scripts": {
    "mongo:up": "docker compose up -d",
    "mongo:down": "docker compose down",

    "api:dev": "npm --prefix fake-api run dev",
    "api:build": "npm --prefix fake-api run build",
    "api:start": "npm --prefix fake-api run start",

    "web:dev": "npm --prefix web-app run dev",
    "web:build": "npm --prefix web-app run build",
    "web:preview": "npm --prefix web-app run preview",

    "test:api": "playwright test tests/api",
    "test:db": "playwright test tests/database",
    "test:playwright": "playwright test tests/api tests/database",
    "test:all": "npm run test:playwright && npm run postman:test",

    "test:e2e": "playwright test tests/e2e",
    "test:e2e:smoke": "playwright test tests/e2e --grep @smoke",
    "test:e2e:dev": "playwright test tests/e2e --headed --retries=0 --reporter=line",
    "test:e2e:ui": "playwright test tests/e2e --ui",
    "test:e2e:debug": "playwright test tests/e2e --debug",

    "test:e2e:visual": "playwright test tests/e2e --grep @visual",
    "test:e2e:visual:update": "playwright test tests/e2e --grep @visual --update-snapshots",

    "test:report": "playwright show-report reports/playwright-report",
    "test:report:port": "playwright show-report reports/playwright-report --port 9324",

    "postman:test": "newman run postman/payments.postman_collection.json -e postman/local.postman_environment.json",

    "install:api": "npm --prefix fake-api install",
    "install:all": "npm install && npm --prefix fake-api install && npm --prefix web-app install"
  },
  "keywords": [
    "qa",
    "qa-automation",
    "api-testing",
    "playwright",
    "typescript",
    "postman",
    "newman",
    "mongodb",
    "payments"
  ],
  "author": "Lucas Eduardo Mota",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "mongodb": "^7.5.0",
    "newman": "^6.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}