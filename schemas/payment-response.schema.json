{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Payment Response Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "amount",
    "currency",
    "paymentMethod",
    "customerDocument",
    "status",
    "statusHistory",
    "testRunId",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pay_"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "enum": ["BRL"]
    },
    "paymentMethod": {
      "type": "string",
      "enum": ["PIX", "BOLETO", "CREDIT_CARD"]
    },
    "customerDocument": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "APPROVED", "REFUSED", "CANCELLED"]
    },
    "statusHistory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "changedAt"],
        "properties": {
          "from": {
            "type": ["string", "null"],
            "enum": ["PENDING", "APPROVED", "REFUSED", "CANCELLED", null]
          },
          "to": {
            "type": "string",
            "enum": ["PENDING", "APPROVED", "REFUSED", "CANCELLED"]
          },
          "changedAt": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "testRunId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
